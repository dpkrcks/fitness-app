# Copy to .env and fill real values locally. NEVER commit a real .env.
# (.gitignore excludes .env / .env.* but keeps this example.)

NODE_ENV=development

# --- API (NestJS) ---
API_PORT=3000
API_GLOBAL_PREFIX=api

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://fitness:fitness@localhost:5432/fitness?schema=public
# Connection pool (set per guidelines: max/min/timeout)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT_MS=30000

# --- Auth (JWT, short-lived access + rotating refresh) ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# --- Object storage (MinIO locally, S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fitness-assets

# --- Observability ---
LOG_LEVEL=debug
