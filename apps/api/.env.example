# Copy to .env and fill in real values. .env is git-ignored — never commit secrets.
# Server vars have safe defaults (see src/config/env.schema.ts); DB vars are required.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database: Neon Postgres (use a "dev" branch) ---
# App runtime -> POOLED endpoint (hostname contains "-pooler").
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
# Migrations / Prisma CLI -> DIRECT endpoint (same host WITHOUT "-pooler").
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"
