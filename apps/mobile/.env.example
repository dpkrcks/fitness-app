# Optional override for the API base URL the app talks to.
#
# Leave this UNSET for local development: the app auto-derives your computer's
# LAN IP from Expo's hostUri, so a device that scanned the QR reaches
# http://<your-pc-ip>:3000/api/v1 automatically.
#
# Set it for staging/production, or when the API runs on a non-default host.
# Must be prefixed with EXPO_PUBLIC_ to be readable in the app at runtime.
# EXPO_PUBLIC_API_URL=https://api.example.com/api/v1
