{
  "name": "@fit/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "Single source of truth for cross-app contracts: zod schemas + inferred TS types.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@fit/config": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
